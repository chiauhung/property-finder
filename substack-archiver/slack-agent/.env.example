# Slack — create app at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token   # Socket Mode token (requires connections:write scope)

# LLM
GOOGLE_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-2.0-flash

# Internal service URLs (set automatically by docker-compose)
MCP_URL=http://mcp-server:8001
ADK_URL=http://adk-agent:8002
